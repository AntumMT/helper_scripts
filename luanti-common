ARGS=$@

# TODO: detect OS
#~ LUANTI_ROOT=/usr/share/minetest
#~ LUANTI_EXEC=/usr/bin/minetest
LUANTI_ROOT="/c/Games/Luanti"
LUANTI_EXEC="/c/Games/Luanti/bin/luanti.exe"

DATA_ROOT="~/GameData/Luanti"
WORLD_ROOT="${DATA_ROOT}/worlds"
CONFIG_ROOT="${DATA_ROOT}/config/${WORLD_NAME}"
WORLD="${WORLD_ROOT}/${WORLD_NAME}"
CONFIG="${CONFIG_ROOT}/minetest.conf"
LOG="${CONFIG_ROOT}/server.log"

if [ "${GAME}" == "antum" ]; then
    LOG="${CONFIG_ROOT}/logs/server-$(show-date).log"
    if [ ! -d "${CONFIG_ROOT}/logs" ]; then
        mkdir -p "${CONFIG_ROOT}/logs"
    fi
elif [ "${GAME}" == "antum-testing" ]; then
    CONFIG="${CONFIG}.example"
fi

SERVER_EXEC_COMMAND="${LUANTI_EXEC} --server --config ${CONFIG} --gameid ${GAME} --world ${WORLD} --port ${PORT} --logfile ${LOG} ${ARGS}"


# Tests

printf "\nTesting for Luanti executable ..."
if [ -f "${LUANTI_EXEC}" ] && [ -x "${LUANTI_EXEC}" ]; then
    printf "\t${LUANTI_EXEC}\n"
else
    printf "\tNO\n"
    exit 1
fi

printf "Testing for game ..."
if [ -d "${LUANTI_ROOT}/games/${GAME}" ]; then
    printf "\t\t\t${LUANTI_ROOT}/games/${GAME}\n"
else
    printf "\t\tNO\n"
    exit 1
fi

printf "Testing for data root ..."
if [ -d "${DATA_ROOT}" ]; then
    printf "\t\t${DATA_ROOT}\n"
else
    printf "\t\tNO\n"
    exit 1
fi

printf "Testing for configuration file ..."
if [ -f "${CONFIG}" ]; then
    printf "\t${CONFIG}\n"
else
    printf "\tNO\n"
    exit 1
fi

printf "Checking for world data ..."
if [ -d "${WORLD}" ]; then
    printf "\t\tusing existing world: ${WORLD}\n"
else
    printf "\t\tcreating new world: ${WORLD}\n"
fi

printf "Checking for log file ..."
if [ -f "${LOG}" ]; then
    printf "\t\tusing existing log: ${LOG}\n"
else
    printf "\t\tcreating new log: ${LOG}\n"
fi

printf "Using port:\t\t\t\t${PORT}\n"


printf "Executing Luanti ...\n\n"
${SERVER_EXEC_COMMAND}

